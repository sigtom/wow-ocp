# Unpoller Environment Variables
# Generated by Ansible

# Tell unpoller to use env vars only
UP_CONFIG_FILE=/dev/null

# Timezone
TZ=America/New_York

# UniFi Controller Configuration
UP_UNIFI_DEFAULT_URL={{ unifi_controller_url | default('https://10.0.0.1/') }}
UP_UNIFI_DEFAULT_USER={{ unifi_controller_user | default('tecro') }}
# Password should be provided via AAP Extra Vars or Bitwarden lookup
UP_UNIFI_DEFAULT_PASS={{ unifi_controller_pass | default('SigmaTheta76') }}
UP_UNIFI_DEFAULT_VERIFY_SSL={{ unifi_verify_ssl | default('false') }}

# Prometheus Configuration
UP_PROMETHEUS_HTTP_LISTEN=0.0.0.0:9130
UP_PROMETHEUS_NAMESPACE=unpoller

# Disable InfluxDB (since we are using Prometheus)
UP_INFLUXDB_DISABLE=true

# Debugging
UP_DEBUG=false
UP_QUIET=false
