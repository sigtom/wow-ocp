# Unpoller Environment Variables
# Generated by Ansible

# Tell unpoller to use env vars only
UP_CONFIG_FILE=/dev/null

# Timezone
TZ=America/New_York

# Enable the built-in troubleshooting Web UI
UP_WEBSERVER_ENABLE=true
UP_WEBSERVER_PORT=37288

# UniFi Controller Configuration
UP_UNIFI_DEFAULT_URL={{ unifi_controller_url | default('https://10.0.0.1/') }}
UP_UNIFI_DEFAULT_USER={{ unifi_controller_user | default('tecro') }}
UP_UNIFI_DEFAULT_PASS={{ unifi_controller_pass | default('SigmaTheta76') }}
UP_UNIFI_DEFAULT_VERIFY_SSL={{ unifi_verify_ssl | default('false') }}

# Prometheus Configuration
UP_PROMETHEUS_HTTP_LISTEN=0.0.0.0:9130
UP_PROMETHEUS_NAMESPACE=unpoller

# InfluxDB Configuration (Enabled for full stack)
UP_INFLUXDB_DISABLE=false
UP_INFLUXDB_URL=http://influxdb:8086
UP_INFLUXDB_DB={{ influxdb_db | default('unpoller') }}
UP_INFLUXDB_USER={{ influxdb_user | default('unpoller') }}
UP_INFLUXDB_PASS={{ influxdb_pass | default('unpoller') }}

# InfluxDB Container Setup
INFLUXDB_DB={{ influxdb_db | default('unpoller') }}
INFLUXDB_ADMIN_USER={{ influxdb_admin_user | default('admin') }}
INFLUXDB_ADMIN_PASSWORD={{ influxdb_admin_password | default('admin123') }}
INFLUXDB_HTTP_AUTH_ENABLED=true

# Grafana Configuration
GRAFANA_USERNAME={{ grafana_admin_user | default('admin') }}
GRAFANA_PASSWORD={{ grafana_admin_password | default('admin123') }}

# Debugging
UP_DEBUG=false
UP_QUIET=false
