# Unpoller Environment Variables
# Generated by Ansible

# Tell unpoller to use env vars only
UP_CONFIG_FILE=/dev/null

# Timezone
TZ=America/New_York

# Disable built-in troubleshooting Web UI
UP_WEBSERVER_ENABLE=false

# UniFi Controller 0 (Home UDM Pro SE)
UP_UNIFI_0_URL={{ unifi_controller_url | default('https://10.0.0.1/') }}
UP_UNIFI_0_USER={{ unifi_controller_user | default('tecro') }}
UP_UNIFI_0_PASS={{ unifi_controller_pass | default('SigmaTheta76') }}
UP_UNIFI_0_VERIFY_SSL={{ unifi_verify_ssl | default('false') }}

# UniFi Controller 1 (New Instance)
UP_UNIFI_1_URL={{ unifi_controller_1_url | default('https://10.1.1.1/') }}
UP_UNIFI_1_USER={{ unifi_controller_1_user | default('wowro') }}
UP_UNIFI_1_PASS={{ unifi_controller_1_pass | default('D@yl1ghtSh@rp3n#') }}
UP_UNIFI_1_VERIFY_SSL={{ unifi_verify_ssl_1 | default('false') }}

# Global Polling Interval
UP_UNIFI_DEFAULT_INTERVAL=120s

# Prometheus Configuration
UP_PROMETHEUS_HTTP_LISTEN=0.0.0.0:9130
UP_PROMETHEUS_NAMESPACE=unpoller

# InfluxDB Configuration
UP_INFLUXDB_DISABLE=false
UP_INFLUXDB_URL=http://influxdb:8086
UP_INFLUXDB_DB={{ influxdb_db | default('unpoller') }}
UP_INFLUXDB_USER={{ influxdb_user | default('unpoller') }}
UP_INFLUXDB_PASS={{ influxdb_pass | default('unpoller') }}

# InfluxDB Container Setup
INFLUXDB_DB={{ influxdb_db | default('unpoller') }}
INFLUXDB_ADMIN_USER={{ influxdb_admin_user | default('admin') }}
INFLUXDB_ADMIN_PASSWORD={{ influxdb_admin_password | default('admin123') }}
INFLUXDB_HTTP_AUTH_ENABLED=false

# Grafana Configuration
GRAFANA_USERNAME={{ grafana_admin_user | default('admin') }}
GRAFANA_PASSWORD={{ grafana_admin_password | default('admin123') }}

# Debugging
UP_DEBUG=false
UP_QUIET=false
